props.dislikeCounter}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Post;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\dialogs-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\profile-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\redux-state.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\MyPosts\\MyPostsContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\DialogsContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Users\\Users.js",["151"],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Users\\UsersContainer.js",["152"],[],"import axios from \"axios\";\r\nimport React from \"react\";\r\nimport Users from \"./Users\";\r\nimport { connect } from \"react-redux\";\r\nimport {\r\n  follow,\r\n  unfollow,\r\n  setUsers,\r\n  setCurrentPage,\r\n  setTotalUsers,\r\n  toggleIsFetching,\r\n} from \"../Redux/users-reducer\";\r\nimport Preloader from \"../common/Preloader/Preloader\";\r\n\r\nclass UsersContainer extends React.Component {\r\n  componentDidMount() {\r\n    this.props.toggleIsFetching(true);\r\n    if (this.props.users.length === 0) {\r\n      axios\r\n        .get(\r\n          `https://social-network.samuraijs.com/api/1.0/users?page=${this.props.currentPage}&count=${this.props.pageSize}`\r\n        )\r\n        .then((response) => {\r\n          this.props.toggleIsFetching(false);\r\n          this.props.setUsers(response.data.items);\r\n          this.props.setTotalUsers(response.data.totalCount);\r\n        });\r\n    }\r\n  }\r\n\r\n  onPageChanged = (page) => {\r\n    this.props.setCurrentPage(page);\r\n    this.props.toggleIsFetching(true);\r\n    axios\r\n      .get(\r\n        `https://social-network.samuraijs.com/api/1.0/users?page=${page}&count=${this.props.pageSize}`\r\n      )\r\n      .then((response) => {\r\n        this.props.toggleIsFetching(false);\r\n        this.props.setUsers(response.data.items);\r\n      });\r\n  };\r\n\r\n  render() {\r\n    return (\r\n      <>\r\n        {this.props.isFetching ? (\r\n          <Preloader isFetching={this.props.isFetching} />\r\n        ) : null}\r\n        <Users\r\n          currentPage={this.props.currentPage}\r\n          totalUsers={this.props.totalUsers}\r\n          pageSize={this.props.pageSize}\r\n          users={this.props.users}\r\n          isFetching={this.props.isFetching}\r\n          follow={this.props.follow}\r\n          unfollow={this.props.unfollow}\r\n          onPageChanged={this.onPageChanged}\r\n          toggleIsFetching={this.props.toggleIsFetching}\r\n        />\r\n      </>\r\n    );\r\n  }\r\n}\r\n\r\nlet mapStateToProps = (state) => {\r\n  return {\r\n    users: state.usersPage.users,\r\n    pageSize: state.usersPage.pageSize,\r\n    totalUsers: state.usersPage.totalUsers,\r\n    currentPage: state.usersPage.currentPage,\r\n    isFetching: state.usersPage.isFetching,\r\n  };\r\n};\r\n\r\nexport default connect(mapStateToProps, {\r\n  follow,\r\n  unfollow,\r\n  setUsers,\r\n  setCurrentPage,\r\n  setTotalUsers,\r\n  toggleIsFetching,\r\n})(UsersContainer);\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\users-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\common\\Preloader\\Preloader.js",["153"],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\ProfileContainer.js",[],[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\auth-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Header\\HeaderContainer.js",[],[],{"ruleId":"154","severity":1,"message":"155","line":1,"column":8,"nod