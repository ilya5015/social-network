uments\\social-network\\social-network\\src\\components\\Users\\Users.js",["140"],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Users\\UsersContainer.js",["141"],[],"import axios from \"axios\";\r\nimport React from \"react\";\r\nimport Users from \"./Users\";\r\nimport { connect } from \"react-redux\";\r\nimport {\r\n  follow,\r\n  unfollow,\r\n  setUsers,\r\n  setCurrentPage,\r\n  setTotalUsers,\r\n  toggleIsFetching,\r\n} from \"../Redux/users-reducer\";\r\nimport Preloader from \"../common/Preloader/Preloader\";\r\n\r\nclass UsersContainer extends React.Component {\r\n  componentDidMount() {\r\n    this.props.toggleIsFetching(true);\r\n    if (this.props.users.length === 0) {\r\n      axios\r\n        .get(\r\n          `https://social-network.samuraijs.com/api/1.0/users?page=${this.props.currentPage}&count=${this.props.pageSize}`\r\n        )\r\n        .then((response) => {\r\n          this.props.toggleIsFetching(false);\r\n          this.props.setUsers(response.data.items);\r\n          this.props.setTotalUsers(response.data.totalCount);\r\n        });\r\n    }\r\n  }\r\n\r\n  onPageChanged = (page) => {\r\n    this.props.setCurrentPage(page);\r\n    this.props.toggleIsFetching(true);\r\n    axios\r\n      .get(\r\n        `https://social-network.samuraijs.com/api/1.0/users?page=${page}&count=${this.props.pageSize}`\r\n      )\r\n      .then((response) => {\r\n        this.props.toggleIsFetching(false);\r\n        this.props.setUsers(response.data.items);\r\n      });\r\n  };\r\n\r\n  render() {\r\n    return (\r\n      <>\r\n        {this.props.isFetching ? (\r\n          <Preloader isFetching={this.props.isFetching} />\r\n        ) : null}\r\n        <Users\r\n          currentPage={this.props.currentPage}\r\n          totalUsers={this.props.totalUsers}\r\n          pageSize={this.props.pageSize}\r\n          users={this.props.users}\r\n          isFetching={this.props.isFetching}\r\n          follow={this.props.follow}\r\n          unfollow={this.props.unfollow}\r\n          onPageChanged={this.onPageChanged}\r\n          toggleIsFetching={this.props.toggleIsFetching}\r\n        />\r\n      </>\r\n    );\r\n  }\r\n}\r\n\r\nlet mapStateToProps = (state) => {\r\n  return {\r\n    users: state.usersPage.users,\r\n    pageSize: state.usersPage.pageSize,\r\n    totalUsers: state.usersPage.totalUsers,\r\n    currentPage: state.usersPage.currentPage,\r\n    isFetching: state.usersPage.isFetching,\r\n  };\r\n};\r\n\r\nexport default connect(mapStateToProps, {\r\n  follow,\r\n  unfollow,\r\n  setUsers,\r\n  setCurrentPage,\r\n  setTotalUsers,\r\n  toggleIsFetching,\r\n})(UsersContainer);\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\users-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\common\\Preloader\\Preloader.js",["142"],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\ProfileContainer.js",[],[],{"ruleId":"143","severity":1,"message":"144","line":1,"column":8,"nodeType":"145","messageId":"146","endLine":1,"endColumn":14},{"ruleId":"143","severity":1,"message":"147","line":2,"column":8,"nodeType":"145","messageId":"146","endLine":2,"endColumn":13},{"ruleId":"148","severity":1,"message":"149","line":13,"column":9,"nodeType":"150","endLine":13,"endColumn":64},{"ruleId":"148","severity":1,"message":"149","line":7,"column":7,"nodeType":"150","endLine":7,"endColumn":27},{"ruleId":"148","severity":1,"message":"149","line":36,"column":19,"nodeType":"150","endLine":45,"endColumn":21},{"ruleId":"143","severity":1,"message":"151","line":76,"column":5,"nodeType":"145","messageId":"146","endLine":76,"endColumn":23},{"ruleId":"148","severity":1,"message":"149","line":8,"column":9,"nodeType":"150","endLine":8,"endColumn":59},"no-unused-vars","'styles' is defined but never used.","Identifier","unusedVar","'anime' is defined but never used.","jsx-a11y/alt-text","img eleme