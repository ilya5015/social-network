 MyPostsContainer from \"./MyPosts/MyPostsContainer\";\r\n\r\nconst Profile = (props) => {\r\n  return (\r\n    <div>\r\n      <ProfileInfo profile={props.profile} />\r\n      <MyPostsContainer\r\n        postData={props.state.postData}\r\n        dispatch={props.dispatch}\r\n      />\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Profile;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\Dialogs.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\News\\News.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Settings\\Settings.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Music\\Music.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Navbar\\Navbar.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\MyPosts\\MyPosts.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\DialogMessage\\DialogMessage.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\ProfileInfo\\ProfileInfo.js",["171","172"],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\DialogItem\\DialogItem.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\MyPosts\\Post\\Post.js",["173"],[],"import styles from \"./Post.module.css\";\r\nimport avatar from \"./avatar.jpg\";\r\n\r\nconst Post = (props) => {\r\n  return (\r\n    <div className={styles.post}>\r\n      <img src={avatar} />\r\n      {props.message}\r\n      <div>\r\n        <span>LIKE</span>:{props.likeCounter}\r\n      </div>\r\n      <div>\r\n        <span>DISLIKE</span>:{props.dislikeCounter}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Post;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\dialogs-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\profile-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\redux-state.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\MyPosts\\MyPostsContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\DialogsContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Users\\Users.js",["174"],[],"import { NavLink } from \"react-router-dom\";\r\nimport styles from \"./Users.module.css\";\r\n\r\nconst Users = (props) => {\r\n  let pagesCount = Math.ceil(props.totalUsers / props.pageSize);\r\n  let pages = [];\r\n  for (let i = 1; i <= pagesCount; i++) {\r\n    pages.push(i);\r\n  }\r\n\r\n  return (\r\n    <div>\r\n      <div>\r\n        {pages.map((page) => {\r\n          return (\r\n            <span\r\n              className={\r\n                props.currentPage === page ? styles.selectedPage : styles.page\r\n              }\r\n              onClick={() => {\r\n                props.onPageChanged(page);\r\n              }}\r\n            >\r\n              {page}\r\n            </span>\r\n          );\r\n        })}\r\n      </div>\r\n\r\n      <div>\r\n        {props.users.map((user) => (\r\n          <div key={user.id}>\r\n            <span>\r\n              <div>\r\n                <NavLink to={`/profile/${user.id}`}>\r\n                  <img\r\n                    src={\r\n                      user.photos.small != null\r\n                        ? (user.photos.small =\r\n                            \"https://temperaturka.com/wp-content/uploads/5/d/f/5dfafb5bc640c3978688e632a5aa46f3.jpe\")\r\n                        : user.photos.small\r\n                    }\r\n                    width=\"100\"\r\n                    height=\"100\"\r\n                  />\r\n                </NavLink>\r\n              </div>\r\n              <div>\r\n                {user.followed ? (\r\n                  <button\r\n                    disabled={props.followingInProgressUsers.some(\r\n                      (userId) => user.id === userId\r\n                    )}\r\n                    onClick={() => {\r\n                      props.unfollow(user.id);\r\n                    }}\r\n                  >\r\n                    Unfollow\r\n                  </button>\r\n                ) : (\r\n                  <button\r\n                    disabled={props.followingInProgressUsers.some(\r\n                      (userId) => user.id === userId\r\n                    )}\r\n                    onClick={() => {\r\n                      props.follow(user.id);\r\n                    }}\r\n                  >\r\n                    Follow\r\n                  </button>\r\n                )}\r\n              </div>\r\n            </span>\r\n            <span>\r\n              <span>\r\n                <div>{user.name}</div>\r\n                <div>{user.status}</div>\r\n              </span>\r\n              <span>\r\n                <div>{\"user.location.city\"}</div>\r\n                <div>{\"user.location.country\"}</div>\r\n              </span>\r\n            </span>\r\n          </div>\r\n        ))}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Users;\r\n",[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Users\\UsersContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\users-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\common\\Preloader\\Preloader.js",["175"],[],"import React from \"react\";\r\nimport preloader from \"../../../assets/preloader.gif\";\r\n\r\nconst Preloader = (props) => {\r\n  return (\r\n    <div>\r\n      {props.isFetching ? (\r\n        <img src={preloader} style={{ width: \"100px\" }} />\r\n      ) : null}\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Preloader;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\ProfileContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\auth-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Header\\HeaderContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\api\\api.js",[],[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Login\\Login.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\HOC\\WithAuthRedirect.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\ProfileInfo\\ProfileStatus\\ProfileStatus.js",[],[],{"ruleId":"176","severity":1,"message":"177","line":1,"column":8,"nodeType":"178","messageId":"179","endLine":1,"endColumn":14},{"ruleId":"176","severity":1,"message":"180","line":2,"column":8,"nodeType":"178","messageId":"179","endLine":2,"endColumn":13},{"ruleId":"176","severity":1,"message":"181","line":3,"column":8,"nodeType":"178","messageId":"179","endLine":3,"endColumn":17},{"ruleId":"182","severity":1,"message":"183","line":7,"column":7,"nodeType":"184","endLine":7,"endColumn":27},{"ruleId":"182","severity":1,"message":"183","line":36,"column":19,"nodeType":"184","endLine":45,"endColumn":21},{"ruleId":"182","severity":1,"message":"183","line":8,"column":9,"nodeType":"184","endLine":8,"endColumn":59},"no-unused-vars","'styles' is defined but never used.","Identifier","unusedVar","'anime' is defined but never used.","'Preloader' is defined but never used.","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement"]