 \"./Post.module.css\";\r\nimport avatar from \"./avatar.jpg\";\r\n\r\nconst Post = (props) => {\r\n  return (\r\n    <div className={styles.post}>\r\n      <img src={avatar} />\r\n      {props.message}\r\n      <div>\r\n        <span>LIKE</span>:{props.likeCounter}\r\n      </div>\r\n      <div>\r\n        <span>DISLIKE</span>:{props.dislikeCounter}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Post;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\dialogs-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\profile-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\redux-state.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\MyPosts\\MyPostsContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\DialogsContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Users\\Users.js",["157"],[],"import { NavLink } from \"react-router-dom\";\r\nimport { usersApi } from \"../../api/api\";\r\nimport styles from \"./Users.module.css\";\r\n\r\nconst Users = (props) => {\r\n  let pagesCount = Math.ceil(props.totalUsers / props.pageSize);\r\n  let pages = [];\r\n  for (let i = 1; i <= pagesCount; i++) {\r\n    pages.push(i);\r\n  }\r\n\r\n  return (\r\n    <div>\r\n      <div>\r\n        {pages.map((page) => {\r\n          return (\r\n            <span\r\n              className={\r\n                props.currentPage === page ? styles.selectedPage : styles.page\r\n              }\r\n              onClick={() => {\r\n                props.onPageChanged(page);\r\n              }}\r\n            >\r\n              {page}\r\n            </span>\r\n          );\r\n        })}\r\n      </div>\r\n\r\n      <div>\r\n        {props.users.map((user) => (\r\n          <div key={user.id}>\r\n            <span>\r\n              <div>\r\n                <NavLink to={`/profile/${user.id}`}>\r\n                  <img\r\n                    src={\r\n                      user.photos.small != null\r\n                        ? (user.photos.small =\r\n                            \"https://temperaturka.com/wp-content/uploads/5/d/f/5dfafb5bc640c3978688e632a5aa46f3.jpe\")\r\n                        : user.photos.small\r\n                    }\r\n                    width=\"100\"\r\n                    height=\"100\"\r\n                  />\r\n                </NavLink>\r\n              </div>\r\n              <div>\r\n                {user.followed ? (\r\n                  <button\r\n                    disabled={props.followingInProgressUsers.some(\r\n                      (userId) => user.id === userId\r\n                    )}\r\n                    onClick={() => {\r\n                      props.toggleFollowingProcess(true, user.id);\r\n                      usersApi.unfollowUser(user.id).then((data) => {\r\n                        if (data.resultCode === 0) {\r\n                          props.unfollow(user.id);\r\n                        }\r\n                        props.toggleFollowingProcess(false, user.id);\r\n                      });\r\n                    }}\r\n                  >\r\n                    Unfollow\r\n                  </button>\r\n                ) : (\r\n                  <button\r\n                    disabled={props.followingInProgressUsers.some(\r\n                      (userId) => user.id === userId\r\n                    )}\r\n                    onClick={() => {\r\n                      props.toggleFollowingProcess(true, user.id);\r\n                      usersApi.followUser(user.id).then((data) => {\r\n                        if (data.resultCode === 0) {\r\n                          props.follow(user.id);\r\n                        }\r\n                        props.toggleFollowingProcess(false, user.id);\r\n                      });\r\n                    }}\r\n                  >\r\n                    Follow\r\n                  </button>\r\n                )}\r\n              </div>\r\n            </span>\r\n            <span>\r\n              <span>\r\n                <div>{user.name}</div>\r\n                <div>{user.status}</div>\r\n              </span>\r\n              <span>\r\n                <div>{\"user.location.city\"}</div>\r\n                <div>{\"user.location.country\"}</div>\r\n              </span>\r\n            </span>\r\n          </div>\r\n        ))}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Users;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Users\\UsersContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\users-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\common\\Preloader\\Preloader.js",["158"],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\ProfileContainer.js",[],[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\auth-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Header\\HeaderContainer.js",[],[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\api\\api.js",[],[],{"ruleId":"159","severity":1,"message":"160","line":1,"column":8,"nodeType":"161","messageId":"162","endLine":1,"endColumn":14},{"ruleId":"159","severity":1,"message":"163","line":2,"column":8,"nodeType":"161","messageId":"162","endLine":2,"endColumn":13},{"ruleId":"164","severity":1,"message":"165","line":13,"column":9,"nodeType":"166","endLine":13,"endColumn":64},{"ruleId":"164","severity":1,"message":"165","line":7,"column":7,"nodeType":"166","endLine":7,"endColumn":27},{"ruleId":"164","severity":1,"message":"165","line":37,"column":19,"nodeType":"166","endLine":46,"endColumn":21},{"rul