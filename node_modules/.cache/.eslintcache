SLIKE</span>:{props.dislikeCounter}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Post;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\dialogs-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\profile-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\redux-state.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\MyPosts\\MyPostsContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\DialogsContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Users\\Users.js",["152"],[],"import axios from \"axios\";\r\nimport { NavLink } from \"react-router-dom\";\r\nimport styles from \"./Users.module.css\";\r\n\r\nconst Users = (props) => {\r\n  let pagesCount = Math.ceil(props.totalUsers / props.pageSize);\r\n  let pages = [];\r\n  for (let i = 1; i <= pagesCount; i++) {\r\n    pages.push(i);\r\n  }\r\n\r\n  return (\r\n    <div>\r\n      <div>\r\n        {pages.map((page) => {\r\n          return (\r\n            <span\r\n              className={\r\n                props.currentPage === page ? styles.selectedPage : styles.page\r\n              }\r\n              onClick={() => {\r\n                props.onPageChanged(page);\r\n              }}\r\n            >\r\n              {page}\r\n            </span>\r\n          );\r\n        })}\r\n      </div>\r\n\r\n      <div>\r\n        {props.users.map((user) => (\r\n          <div key={user.id}>\r\n            <span>\r\n              <div>\r\n                <NavLink to={`/profile/${user.id}`}>\r\n                  <img\r\n                    src={\r\n                      user.photos.small != null\r\n                        ? (user.photos.small =\r\n                            \"https://temperaturka.com/wp-content/uploads/5/d/f/5dfafb5bc640c3978688e632a5aa46f3.jpe\")\r\n                        : user.photos.small\r\n                    }\r\n                    width=\"100\"\r\n                    height=\"100\"\r\n                  />\r\n                </NavLink>\r\n              </div>\r\n              <div>\r\n                {user.followed ? (\r\n                  <button\r\n                    onClick={() => {\r\n                      axios\r\n                        .delete(\r\n                          `https://social-network.samuraijs.com/api/1.0//follow/${user.id}`,\r\n                          {\r\n                            withCredentials: true,\r\n                            headers: {\r\n                              \"API-KEY\": \"433355e7-ada0-415d-b257-f31539d272e1\",\r\n                            },\r\n                          }\r\n                        )\r\n                        .then((response) => {\r\n                          if (response.data.resultCode === 0) {\r\n                            props.unfollow(user.id);\r\n                          }\r\n                        });\r\n                    }}\r\n                  >\r\n                    Unfollow\r\n                  </button>\r\n                ) : (\r\n                  <button\r\n                    onClick={() => {\r\n                      axios\r\n                        .post(\r\n                          `https://social-network.samuraijs.com/api/1.0//follow/${user.id}`,\r\n                          {},\r\n                          {\r\n                            withCredentials: true,\r\n                            headers: {\r\n                              \"API-KEY\": \"433355e7-ada0-415d-b257-f31539d272e1\",\r\n                            },\r\n                          }\r\n                        )\r\n                        .then((response) => {\r\n                          if (response.data.resultCode === 0) {\r\n                            props.follow(user.id);\r\n                          }\r\n                        });\r\n                    }}\r\n                  >\r\n                    Follow\r\n                  </button>\r\n                )}\r\n              </div>\r\n            </span>\r\n            <span>\r\n              <span>\r\n                <div>{user.name}</div>\r\n                <div>{user.status}</div>\r\n              </span>\r\n              <span>\r\n                <div>{\"user.location.city\"}</div>\r\n                <div>{\"user.location.country\"}</div>\r\n              </span>\r\n            </span>\r\n          </div>\r\n        ))}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Users;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Users\\UsersContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\users-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\common\\Preloader\\Preloader.js",["153"],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\ProfileContainer.js",[],[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\auth-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Header\\HeaderContainer.js",[],[],[],{"ruleId":"154","severity":1,"message":"155","line":1,"column":8,"nodeType":"156","messageId":"157","endLine":1,"endColumn":14},{"ruleId":"154","severity":1,"message":"158","line":2,"column":8,"nodeType":"156","messageId":"157","endLine":2,"endColumn":13},{"ruleId":"159","severity":1,"message":"160","line":13,"column":9,"nodeType":"161","endLine":13,"endColumn":64},{"ruleId":"159","severity":1,"message":"160","line":7,"column":7,"nodeType":"161","endLine":7,"endColumn":27},{"ruleId":"159","severity":1,"message":"160","line":37,"column":19,"nodeType":"161","endLine":46,"endColumn":21},{"ruleId":"159","severity":1,"message":"160","lin