;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\Dialogs.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\News\\News.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Settings\\Settings.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Music\\Music.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Navbar\\Navbar.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\MyPosts\\MyPosts.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\DialogMessage\\DialogMessage.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\ProfileInfo\\ProfileInfo.js",["167","168"],[],"import styles from \"./ProfileInfo.module.css\";\r\nimport anime from \"../anime.png\";\r\nimport Preloader from \"../../common/Preloader/Preloader\";\r\n\r\nconst ProfileInfo = (props) => {\r\n  if (!props.profile) {\r\n    return <Preloader />;\r\n  }\r\n\r\n  return (\r\n    <div>\r\n      <div>\r\n        <img src={props.profile.photos.large} width=\"1000px\" />\r\n      </div>\r\n      <div>{console.log(props.profile)}</div>\r\n      <div className={styles.descriptionBlock}>avatar + description</div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default ProfileInfo;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\DialogItem\\DialogItem.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\MyPosts\\Post\\Post.js",["169"],[],"import styles from \"./Post.module.css\";\r\nimport avatar from \"./avatar.jpg\";\r\n\r\nconst Post = (props) => {\r\n  return (\r\n    <div className={styles.post}>\r\n      <img src={avatar} />\r\n      {props.message}\r\n      <div>\r\n        <span>LIKE</span>:{props.likeCounter}\r\n      </div>\r\n      <div>\r\n        <span>DISLIKE</span>:{props.dislikeCounter}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Post;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\dialogs-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\profile-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\redux-state.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\MyPosts\\MyPostsContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\DialogsContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Users\\Users.js",["170"],[],"import { NavLink } from \"react-router-dom\";\r\nimport styles from \"./Users.module.css\";\r\n\r\nconst Users = (props) => {\r\n  let pagesCount = Math.ceil(props.totalUsers / props.pageSize);\r\n  let pages = [];\r\n  for (let i = 1; i <= pagesCount; i++) {\r\n    pages.push(i);\r\n  }\r\n\r\n  return (\r\n    <div>\r\n      <div>\r\n        {pages.map((page) => {\r\n          return (\r\n            <span\r\n              className={\r\n                props.currentPage === page ? styles.selectedPage : styles.page\r\n              }\r\n              onClick={() => {\r\n                props.onPageChanged(page);\r\n              }}\r\n            >\r\n              {page}\r\n            </span>\r\n          );\r\n        })}\r\n      </div>\r\n\r\n      <div>\r\n        {props.users.map((user) => (\r\n          <div key={user.id}>\r\n            <span>\r\n              <div>\r\n                <NavLink to={`/profile/${user.id}`}>\r\n                  <img\r\n                    src={\r\n                      user.photos.small != null\r\n                        ? (user.photos.small =\r\n                            \"https://temperaturka.com/wp-content/uploads/5/d/f/5dfafb5bc640c3978688e632a5aa46f3.jpe\")\r\n                        : user.photos.small\r\n                    }\r\n                    width=\"100\"\r\n                    height=\"100\"\r\n                  />\r\n                </NavLink>\r\n              </div>\r\n              <div>\r\n                {user.followed ? (\r\n                  <button\r\n                    disabled={props.followingInProgressUsers.some(\r\n                      (userId) => user.id === userId\r\n                    )}\r\n                    onClick={() => {\r\n                      props.unfollow(user.id);\r\n                    }}\r\n                  >\r\n                    Unfollow\r\n                  </button>\r\n                ) : (\r\n                  <button\r\n                    disabled={props.followingInProgressUsers.some(\r\n                      (userId) => user.id === userId\r\n                    )}\r\n                    onClick={() => {\r\n                      props.follow(user.id);\r\n                    }}\r\n                  >\r\n                    Follow\r\n                  </button>\r\n                )}\r\n              </div>\r\n            </span>\r\n            <span>\r\n              <span>\r\n                <div>{user.name}</div>\r\n                <div>{user.status}</div>\r\n              </span>\r\n              <span>\r\n                <div>{\"user.location.city\"}</div>\r\n                <div>{\"user.location.country\"}</div>\r\n              </span>\r\n            </span>\r\n          </div>\r\n        ))}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Users;\r\n",[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Users\\UsersContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\users-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\common\\Preloader\\Preloader.js",["171"