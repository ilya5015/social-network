\\social-network\\src\\components\\Profile\\Profile.js",["114"],[],"import styles from \"./Profile.module.css\";\r\nimport ProfileInfo from \"./ProfileInfo/ProfileInfo\";\r\nimport MyPostsContainer from \"./MyPosts/MyPostsContainer\";\r\n\r\nconst Profile = (props) => {\r\n  return (\r\n    <div>\r\n      <ProfileInfo />\r\n      <MyPostsContainer\r\n        postData={props.state.postData}\r\n        dispatch={props.dispatch}\r\n      />\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Profile;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\Dialogs.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\News\\News.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Settings\\Settings.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Music\\Music.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Navbar\\Navbar.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\MyPosts\\MyPosts.js",["115"],[],"import styles from \"./MyPosts.module.css\";\r\nimport Post from \"./Post/Post\";\r\nimport { createRef, useRef } from \"react\";\r\n\r\nconst MyPosts = (props) => {\r\n  let postElements = props.postData.map((post) => {\r\n    return (\r\n      <Post\r\n        message={post.message}\r\n        likeCounter={post.likeCounter}\r\n        dislikeCounter={post.dislikeCounter}\r\n      />\r\n    );\r\n  });\r\n\r\n  let newPost = createRef();\r\n\r\n  let onPostChange = () => {\r\n    let postMessage = newPost.current.value;\r\n    props.addPostMessage(postMessage);\r\n  };\r\n\r\n  let postPost = () => {\r\n    props.addPost();\r\n    newPost.current.value = \"\";\r\n  };\r\n\r\n  return (\r\n    <div className={styles.postsBlock}>\r\n      my posts\r\n      <div>\r\n        <div className=\"field-row-stacked\">\r\n          <textarea onChange={onPostChange} ref={newPost} rows=\"8\"></textarea>\r\n        </div>\r\n        <button onClick={postPost}>Add new post</button>\r\n      </div>\r\n      <div className={styles.posts}>{postElements}</div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default MyPosts;\r\n",[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\DialogMessage\\DialogMessage.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\ProfileInfo\\ProfileInfo.js",["116"],[],"import styles from \"./ProfileInfo.module.css\";\r\nimport anime from \"../anime.png\";\r\n\r\nconst ProfileInfo = () => {\r\n  return (\r\n    <div>\r\n      <div>\r\n        <img src={anime} width=\"1000px\" />\r\n      </div>\r\n      <div className={styles.descriptionBlock}>avatar + description</div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default ProfileInfo;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\DialogItem\\DialogItem.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\MyPosts\\Post\\Post.js",["117"],[],"import styles from \"./Post.module.css\";\r\nimport avatar from \"./avatar.jpg\";\r\n\r\nconst Post = (props) => {\r\n  return (\r\n    <div className={styles.post}>\r\n      <img src={avatar} />\r\n      {props.message}\r\n      <div>\r\n        <span>LIKE</span>:{props.likeCounter}\r\n      </div>\r\n      <div>\r\n        <span>DISLIKE</span>:{props.dislikeCounter}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Post;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\dialogs-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\profile-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\redux-state.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile