twork\\src\\components\\Settings\\Settings.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Music\\Music.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Navbar\\Navbar.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\MyPosts\\MyPosts.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\DialogMessage\\DialogMessage.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\ProfileInfo\\ProfileInfo.js",["130"],[],"import styles from \"./ProfileInfo.module.css\";\r\nimport anime from \"../anime.png\";\r\n\r\nconst ProfileInfo = () => {\r\n  return (\r\n    <div>\r\n      <div>\r\n        <img src={anime} width=\"1000px\" />\r\n      </div>\r\n      <div className={styles.descriptionBlock}>avatar + description</div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default ProfileInfo;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\DialogItem\\DialogItem.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\MyPosts\\Post\\Post.js",["131"],[],"import styles from \"./Post.module.css\";\r\nimport avatar from \"./avatar.jpg\";\r\n\r\nconst Post = (props) => {\r\n  return (\r\n    <div className={styles.post}>\r\n      <img src={avatar} />\r\n      {props.message}\r\n      <div>\r\n        <span>LIKE</span>:{props.likeCounter}\r\n      </div>\r\n      <div>\r\n        <span>DISLIKE</span>:{props.dislikeCounter}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Post;\r\n","C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\dialogs-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\profile-reducer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\redux-state.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Profile\\MyPosts\\MyPostsContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Dialogs\\DialogsContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Users\\Users.js",["132"],[],"import axios from \"axios\";\r\nimport React from \"react\";\r\nimport styles from \"./Users.module.css\";\r\n\r\nclass Users extends React.Component {\r\n  componentDidMount() {\r\n    if (this.props.users.length === 0) {\r\n      axios\r\n        .get(\r\n          `https://social-network.samuraijs.com/api/1.0/users?page=${this.props.currentPage}&count=${this.props.pageSize}`\r\n        )\r\n        .then((response) => {\r\n          console.log(response);\r\n          this.props.setUsers(response.data.items);\r\n          this.props.setTotalUsers(response.data.totalCount);\r\n        });\r\n    }\r\n  }\r\n\r\n  onPageChanged = (page) => {\r\n    this.props.setCurrentPage(page);\r\n    axios\r\n      .get(\r\n        `https://social-network.samuraijs.com/api/1.0/users?page=${page}&count=${this.props.pageSize}`\r\n      )\r\n      .then((response) => {\r\n        console.log(response);\r\n        this.props.setUsers(response.data.items);\r\n      });\r\n  };\r\n\r\n  render() {\r\n    let pagesCount = Math.ceil(this.props.totalUsers / this.props.pageSize);\r\n    let pages = [];\r\n    for (let i = 1; i <= pagesCount; i++) {\r\n      pages.push(i);\r\n    }\r\n\r\n    return (\r\n      <div>\r\n        <div>\r\n          {pages.map((page) => {\r\n            return (\r\n              <span\r\n                className={\r\n                  this.props.currentPage === page\r\n                    ? styles.selectedPage\r\n                    : styles.page\r\n                }\r\n                onClick={() => {\r\n                  this.onPageChanged(page);\r\n                }}\r\n              >\r\n                {page}\r\n              </span>\r\n            );\r\n          })}\r\n        </div>\r\n\r\n        <div>\r\n          {this.props.users.map((user) => (\r\n            <div key={user.id}>\r\n              <span>\r\n                <div>\r\n                  <img\r\n                    src={\r\n                      user.photos.small != null\r\n                        ? (user.photos.small =\r\n                            \"https://temperaturka.com/wp-content/uploads/5/d/f/5dfafb5bc640c3978688e632a5aa46f3.jpe\")\r\n                        : user.photos.small\r\n                    }\r\n                    width=\"100\"\r\n                    height=\"100\"\r\n                  />\r\n                </div>\r\n                <div>\r\n                  {user.followed ? (\r\n                    <button\r\n                      onClick={() => {\r\n                        this.props.unfollow(user.id);\r\n                      }}\r\n                    >\r\n                      Unfollow\r\n                    </button>\r\n                  ) : (\r\n                    <button\r\n                      onClick={() => {\r\n                        this.props.follow(user.id);\r\n                      }}\r\n                    >\r\n                      Follow\r\n                    </button>\r\n                  )}\r\n                </div>\r\n              </span>\r\n              <span>\r\n                <span>\r\n                  <div>{user.name}</div>\r\n                  <div>{user.status}</div>\r\n                </span>\r\n                <span>\r\n                  <div>{\"user.location.city\"}</div>\r\n                  <div>{\"user.location.country\"}</div>\r\n                </span>\r\n              </span>\r\n            </div>\r\n          ))}\r\n        </div>\r\n      </div>\r\n    );\r\n  }\r\n}\r\n\r\nexport default Users;\r\n",[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Users\\UsersContainer.js",[],[],"C:\\Users\\Ilya\\Documents\\social-network\\social-network\\src\\components\\Redux\\users-reducer.js",[],[],{"ruleId":"133","severity":1,"message":"134","line":1,"column":8,"nodeType":"135","messageId":"136","endLine":1,"endColumn":14},{"ruleId":"137","severity":1,"message":"138","line":8,"column":9,"nodeType":"139","endLine":8,"endColumn":43},{"ruleId":"137","severity":1,"message":"138","line":7,"column":7,"nodeType":"139","endLine":7,"endColumn":27},{"ruleId":"137","severity":1,"message":"138","line":64,"column":19,"nodeType":"139","endLine":73,"endColumn":21},"no-unused-vars","'styles' is defined but never used.","Identifier","unusedVar","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement"]